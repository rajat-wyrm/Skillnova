generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())

  // BASIC INFO
  name      String?
  email     String?  @unique
  password  String?
  role      String   @default("intern")

  // 🔥 AUTH METHODS
  googleId  String?  @unique
  phone     String?  @unique

  // 🔐 OTP SYSTEM
  otpCode   String?
  otpExpiry DateTime?

  // META
  isVerified Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  // RELATIONS
  qa        QA[]
  reports   Report[]
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdBy String
  createdAt DateTime @default(now())
}

model Article {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdBy String
  createdAt DateTime @default(now())
}

model QA {
  id         String   @id @default(cuid())
  question   String
  answer     String
  confidence Float    @default(0)
  userId     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id        String   @id @default(cuid())
  title     String
  fileUrl   String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}