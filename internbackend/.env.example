# SkillNova / InternOps environment template.
# Copy to .env and fill in. All values are optional unless flagged.

# Core
NODE_ENV=development
HOST=0.0.0.0
PORT=5000

# Database (Postgres in production; required)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/skillnova

# Auth — MUST be set in production
JWT_SECRET=replace-with-a-long-random-string

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# Redis (optional; Upstash REST supported)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# CSRF
CSRF_SECRET=replace-with-a-long-random-string

# Mail (password reset etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@skillnova.local

# LLM keys (Python AI chatbot, optional)
GROQ_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
TAVILY_API_KEY=
HUGGINGFACE_API_KEY=
EMBEDDING_BACKEND=local