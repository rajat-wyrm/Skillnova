# SkillNova AI Chatbot — Backend Environment
#
# Copy this file to `.env` and fill in real values for your machine.
# DO NOT commit `.env` to version control.
#
# At least one LLM provider key MUST be set for the service to answer
# questions. Health and session endpoints work without any key.

# ── Server ─────────────────────────────────────────────────────────────
SKILLNOVA_AI_HOST=0.0.0.0
SKILLNOVA_AI_PORT=8000
SKILLNOVA_AI_ENV=development
SKILLNOVA_AI_LOG_LEVEL=INFO

# ── Database (SQLite is used automatically when this is empty) ────────
# Example for Postgres:  postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=

# ── Cache (Redis is optional; in-memory cache is used as fallback) ────
REDIS_URL=

# ── LLM Providers (at least one is required) ──────────────────────────
# Groq — primary
GROQ_API_KEY=

# Google Gemini — fallback 1
GEMINI_API_KEY=

# OpenAI — fallback 2 (optional)
OPENAI_API_KEY=

# DeepSeek — fallback 3 (optional)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# HuggingFace — used for embeddings + optional inference fallback
HUGGINGFACE_API_KEY=
HUGGINGFACE_TOKEN=

# ── Web Search (optional; falls back to DuckDuckGo) ───────────────────
TAVILY_API_KEY=
