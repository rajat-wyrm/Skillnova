{
  "name": "skillnova",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "SkillNova — UptoSkills intern management platform",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "server": "cd server && npm run dev",
    "server:setup": "cd server && npm run setup",
    "server:install": "cd server && npm install",
    "start": "concurrently -k -n web,api -c cyan,magenta \"npm run dev\" \"npm run server\"",
    "setup": "npm install && npm run server:install && npm run server:setup",
    "push": "bash scripts/push.sh"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.5.2",
    "react-loading-skeleton": "^3.5.0",
    "react-markdown": "^9.0.3",
    "react-router-dom": "^7.1.5",
    "recharts": "^3.8.0",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
}
