generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                    @id @default(cuid())
  email              String                    @unique
  passwordHash       String?
  googleId           String?                   @unique
  authProvider       String                    @default("password")
  name               String
  role               UserRole                  @default(INTERN)
  status             UserStatus                @default(PENDING)
  department         String?
  college            String?
  yearOfStudy        String?
  dateOfBirth        DateTime?
  linkedinUrl        String?
  skills             String?
  avatarUrl          String?
  rating             Float                     @default(0)
  twoFactorSecret    String?
  twoFactorEnabled   Boolean                   @default(false)
  emailVerified      Boolean                   @default(false)
  emailVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  lastLoginIp        String?
  failedAttempts     Int                       @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  announcements      Announcement[]            @relation("AnnouncementAuthor")
  announcementsReads AnnouncementRead[]
  answers            Answer[]
  attendances        Attendance[]
  auditLogs          AuditLog[]
  chatSessions       ChatSession[]
  reopenedDailyLogs  DailyWorkLog[]            @relation("DailyWorkLogReopenedBy")
  dailyWorkLogs      DailyWorkLog[]
  mentorOf           InternProfile[]           @relation("MentorRelation")
  internProfile      InternProfile?
  kbArticles         KnowledgeArticle[]        @relation("ArticleAuthor")
  kbVersions         KnowledgeArticleVersion[]
  organizedMeetings  Meeting[]                 @relation("OrganizedMeetings")
  meetingAttendees   MeetingAttendee[]
  mentorProfile      MentorProfile?
  notifications      Notification[]
  projectTasks       ProjectTask[]
  questions          Question[]
  refreshTokens      RefreshToken[]
  reviewedReports    Report[]                  @relation("ReportReviewedBy")
  reports            Report[]                  @relation("UserReports")
  reportReviews      ReportReview[]            @relation("ReportReviewAuthor")
  qaUpvotes          Upvote[]
  sessions           UserSession[]
  authProvider       String                    @default("password")
  googleId           String?                   @unique
  announcements      Announcement[]            @relation("AnnouncementAuthor")
  announcementsReads AnnouncementRead[]
  answers            Answer[]
  attendances        Attendance[]
  auditLogs          AuditLog[]
  chatSessions       ChatSession[]
  mentorOf           InternProfile[]           @relation("MentorRelation")
  internProfile      InternProfile?
  kbArticles         KnowledgeArticle[]        @relation("ArticleAuthor")
  kbVersions         KnowledgeArticleVersion[]
  organizedMeetings  Meeting[]                 @relation("OrganizedMeetings")
  meetingAttendees   MeetingAttendee[]
  mentorProfile      MentorProfile?
  notifications      Notification[]
  projectTasks       ProjectTask[]
  questions          Question[]
  refreshTokens      RefreshToken[]
  reports            Report[]
  qaUpvotes          Upvote[]
  sessions           UserSession[]
  id              String        @id @default(cuid())
  email           String        @unique
  passwordHash    String?
  googleId        String?       @unique
  authProvider    String        @default("password")
  name            String
  role            UserRole      @default(INTERN)
  status          UserStatus    @default(PENDING)
  department      String?
  college         String?
  yearOfStudy     String?
  dateOfBirth     DateTime?
  linkedinUrl     String?
  skills          String?       // comma-separated for simplicity, can migrate to table later
  avatarUrl       String?
  rating          Float         @default(0)
  twoFactorSecret String?
  twoFactorEnabled Boolean      @default(false)
  emailVerified   Boolean       @default(false)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  failedAttempts  Int           @default(0)
  lockedUntil     DateTime?
  currentStreak   Int           @default(0)
  longestStreak   Int           @default(0)
  lastActivityAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  refreshTokens     RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  reports           Report[]
  attendances       Attendance[]
  projectTasks      ProjectTask[]
  announcements     Announcement[]    @relation("AnnouncementAuthor")
  announcementsReads AnnouncementRead[]
  kbArticles        KnowledgeArticle[] @relation("ArticleAuthor")
  kbVersions        KnowledgeArticleVersion[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  questions         Question[]
  answers           Answer[]
  chatSessions      ChatSession[]
  qaUpvotes         Upvote[]
  sessions          UserSession[]
  internProfile     InternProfile?
  mentorProfile     MentorProfile?
  mentorOf          InternProfile[] @relation("MentorRelation")
  organizedMeetings Meeting[]      @relation("OrganizedMeetings")
  meetingAttendees  MeetingAttendee[]
  flagsRaised     Flag[]   @relation("FlaggedByMentor")
  flagsReceived   Flag[]   @relation("FlaggedIntern")
  collaborativeTasksCreated CollaborativeTask[] @relation("TaskCreator")
  collaborativeTasksAssigned CollaborativeTask[] @relation("TaskAssignees")
  teams          Team[]              @relation("TeamMembers")

  @@index([role])
  @@index([status])
  @@index([department])
}

model InternProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  mentorId       String?
  startDate      DateTime
  endDate        DateTime?
  stipend        Float?
  projectId      String?
  totalTasks     Int       @default(0)
  completedTasks Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  mentor         User?     @relation("MentorRelation", fields: [mentorId], references: [id])
  project        Project?  @relation(fields: [projectId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MentorProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  bio        String?
  expertise  String?
  maxInterns Int      @default(10)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  device    String?
  ip        String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  socketId   String?
  ip         String?
  userAgent  String?
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpChallenge {
  id         String    @id @default(cuid())
  email      String
  purpose    String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

model Report {
  id            String         @id @default(cuid())
  userId        String
  title         String
  content       String?
  fileUrl       String?
  weekNumber    Int?
  weekStartDate DateTime?      @db.Date
  weekEndDate   DateTime?      @db.Date
  generatedAt   DateTime?
  status        ReportStatus   @default(DRAFT)
  score         Float?
  feedback      String?
  reviewedById  String?
  reviewedAt    DateTime?
  submittedAt   DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  dailyLogs     DailyWorkLog[]
  reviewedBy    User?          @relation("ReportReviewedBy", fields: [reviewedById], references: [id])
  user          User           @relation("UserReports", fields: [userId], references: [id], onDelete: Cascade)
  reviews       ReportReview[]
  id           String       @id @default(cuid())
  userId       String
  title        String
  content      String?
  fileUrl      String?
  weekNumber   Int?
  status       ReportStatus @default(PENDING)
  score        Float?
  feedback     String?
  reviewedById String?
  reviewedAt   DateTime?
  submittedAt  DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@index([weekStartDate])
}

model DailyWorkLog {
  id               String             @id @default(cuid())
  reportId         String?
  userId           String
  date             DateTime           @db.Date
  workDone         String
  hoursWorked      Float
  technologiesUsed String?
  challenges       String?
  tomorrowPlan     String?
  status           DailyWorkLogStatus @default(OPEN)
  reopenedById     String?
  reopenedAt       DateTime?
  lockedAt         DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  reopenedBy       User?              @relation("DailyWorkLogReopenedBy", fields: [reopenedById], references: [id])
  report           Report?            @relation(fields: [reportId], references: [id])
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([reportId])
  @@index([date])
}

model ReportReview {
  id           String       @id @default(cuid())
  reportId     String
  reviewedById String
  status       ReportStatus
  rating       Int?
  feedback     String?
  createdAt    DateTime     @default(now())
  report       Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reviewedBy   User         @relation("ReportReviewAuthor", fields: [reviewedById], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([reviewedById])
}

model Attendance {
  id         String           @id @default(cuid())
  userId     String
  date       DateTime         @db.Date
  status     AttendanceStatus @default(PRESENT)
  checkIn    DateTime?
  checkOut   DateTime?
  notes      String?
  markedById String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([status])
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus   @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  interns     InternProfile[]
  tasks       ProjectTask[]

  @@index([status])
}

model ProjectTask {
  id          String       @id @default(cuid())
  projectId   String
  assigneeId  String?
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignee    User?        @relation(fields: [assigneeId], references: [id])
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model KnowledgeCategory {
  id          String             @id @default(cuid())
  name        String             @unique
  slug        String             @unique
  description String?
  icon        String?
  order       Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  articles    KnowledgeArticle[]
}

model KnowledgeArticle {
  id           String                    @id @default(cuid())
  title        String
  slug         String                    @unique
  content      String
  excerpt      String?
  categoryId   String
  authorId     String
  status       ArticleStatus             @default(DRAFT)
  verified     Boolean                   @default(false)
  verifiedById String?
  verifiedAt   DateTime?
  views        Int                       @default(0)
  helpful      Int                       @default(0)
  tags         String[]
  embedding    Json?
  publishedAt  DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  feedbacks    ArticleFeedback[]
  author       User                      @relation("ArticleAuthor", fields: [authorId], references: [id])
  category     KnowledgeCategory         @relation(fields: [categoryId], references: [id])
  versions     KnowledgeArticleVersion[]

  @@index([categoryId])
  @@index([status])
  @@index([verified])
  @@index([publishedAt])
}

model KnowledgeArticleVersion {
  id        String           @id @default(cuid())
  articleId String
  version   Int
  title     String
  content   String
  editorId  String
  createdAt DateTime         @default(now())
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  editor    User             @relation(fields: [editorId], references: [id])

  @@unique([articleId, version])
}

model ArticleFeedback {
  id        String           @id @default(cuid())
  articleId String
  userId    String?
  helpful   Boolean
  comment   String?
  createdAt DateTime         @default(now())
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String
  priority    AnnouncementPriority @default(MEDIUM)
  pinned      Boolean              @default(false)
  authorId    String
  publishedAt DateTime             @default(now())
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  author      User                 @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  reads       AnnouncementRead[]

  @@index([pinned])
  @@index([publishedAt])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

model Question {
  id               String   @id @default(cuid())
  title            String
  body             String
  category         String?
  authorId         String
  views            Int      @default(0)
  acceptedAnswerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  answers          Answer[]
  author           User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  upvotes          Upvote[]

  @@index([authorId])
  @@index([createdAt])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  authorId   String
  body       String
  isAccepted Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  upvotes    Upvote[]

  @@index([questionId])
  @@index([authorId])
}

model Upvote {
  id         String    @id @default(cuid())
  userId     String
  questionId String?
  answerId   String?
  createdAt  DateTime  @default(now())
  answer     Answer?   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  question   Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@unique([userId, answerId])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New Chat")
  model     String        @default("llama-3.1-70b-versatile")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  tokens    Int?
  meta      Json?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  meta       Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model SystemSetting {
  key         String   @id
  value       Json
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model FileAsset {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  storage      String
  path         String
  bucket       String?
  uploaderId   String
  visibility   String   @default("private")
  checksum     String
  createdAt    DateTime @default(now())

  @@index([uploaderId])
  @@index([mimeType])
}

model Webhook {
  id           String            @id @default(cuid())
  ownerId      String
  url          String
  events       String[]
  secret       String
  enabled      Boolean           @default(true)
  createdAt    DateTime          @default(now())
  lastFiredAt  DateTime?
  lastStatus   Int?
  failureCount Int               @default(0)
  deliveries   WebhookDelivery[]

  @@index([ownerId])
  @@index([enabled])
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  status     Int
  response   String?
  durationMs Int?
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([event])
}

model NotificationPref {
  id           String   @id @default(cuid())
  userId       String   @unique
  emailEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(true)
  inAppEnabled Boolean  @default(true)
  typePrefs    Json     @default("{}")
  quietFrom    String?
  quietTo      String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model Meeting {
  id          String            @id @default(cuid())
  title       String
  description String?
  type        MeetingType       @default(ONE_ON_ONE)
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  organizerId String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  organizer   User              @relation("OrganizedMeetings", fields: [organizerId], references: [id])
  attendees   MeetingAttendee[]

  @@index([organizerId])
  @@index([startsAt])
}

model MeetingAttendee {
  id        String   @id @default(cuid())
  meetingId String
  userId    String
  response  String   @default("PENDING")
  createdAt DateTime @default(now())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([userId])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MENTOR
  INTERN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_REVISION
  APPROVED
  PENDING
  REVIEWED
  REJECTED
}

enum DailyWorkLogStatus {
  OPEN
  LOCKED
  REOPENED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HALF_DAY
  LATE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnnouncementPriority {
  LOW
  MEDIUM
  HIGH
}

enum MeetingType {
  STANDUP
  ONE_ON_ONE
  REVIEW
  TRAINING
  OTHER
// ── Flags / Alerts ───────────────────────────────────────────
enum FlagType {
  ATTENDANCE_DROPPING
  MISSED_DEADLINE
  NEEDS_SUPPORT
  BEHAVIOUR_CONCERN
  OTHER
}

enum FlagStatus {
  ACTIVE
  RESOLVED
}

model Flag {
  id          String     @id @default(cuid())
  internId    String
  intern      User       @relation("FlaggedIntern", fields: [internId], references: [id], onDelete: Cascade)
  mentorId    String
  mentor      User       @relation("FlaggedByMentor", fields: [mentorId], references: [id])
  type        FlagType
  reason      String?
  status      FlagStatus @default(ACTIVE)
  resolvedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([internId])
  @@index([mentorId])
  @@index([status])
}

// ── Collaborative Task Models ────────────────────────────────

model Team {
  id          String              @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relations
  members     User[]              @relation("TeamMembers")
  tasks       CollaborativeTask[]
}

model CollaborativeTask {
  id          String            @id @default(cuid())
  teamId      String
  team        Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus        @default(TODO)
  creatorId   String
  creator     User              @relation("TaskCreator", fields: [creatorId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Implicit many-to-many relation for multiple assignees
  assignees   User[]            @relation("TaskAssignees")

  @@index([teamId])
  @@index([creatorId])
}
