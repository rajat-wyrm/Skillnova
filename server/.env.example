# ════════════════════════════════════════════════════════════
#  SkillNova — Server Environment Configuration (safe to commit)
#  Copy this file to server/.env and fill in real values.
#  NEVER commit the populated .env file.
# ════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=4000

# Public URL the backend is reachable from (used for OAuth/email redirects)
APP_URL=http://localhost:5273

# Comma-separated list of origins allowed by CORS
CORS_ORIGIN=http://localhost:5273

# ── Database ────────────────────────────────────────────────
# Postgres connection string. Neon / Supabase / RDS all work.
DATABASE_URL=postgresql://user:password@host:5432/skillnova?sslmode=require

# ── Redis (Upstash REST) ────────────────────────────────────
# Empty values disable Redis; the cache falls back to in-memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI Provider (Groq) ──────────────────────────────────────
# Get an API key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Auth Secrets ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_SECRET=
CSRF_SECRET=

# ── Service-to-service API key (signed-URL HMAC seed) ───────
API_KEY=

# ── Token TTLs (seconds) ────────────────────────────────────
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
OTP_TTL=300
TWOFA_TTL=600

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info