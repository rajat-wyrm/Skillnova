# ════════════════════════════════════════════════════════════
#  SkillNova — Server Environment Configuration (safe to commit)
#  Copy this file to server/.env and fill in real values.
#  NEVER commit the populated .env file.
# ════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════
#  SkillNova — Server Environment Configuration (safe to commit)
#  Copy this file to server/.env and fill in real values.
#  NEVER commit the populated .env file.
# ════════════════════════════════════════════════════════════

# Runtime mode. Controls log format and secret enforcement.
# Valid values: development | production | test
NODE_ENV=development

# TCP port the API listens on. Must not conflict with the frontend dev server.
# Valid values: 1-65535. Default: 4000
PORT=4000

# Public URL the backend is reachable from (used for OAuth/email redirects).
# In production this should be your public-facing domain.
# Default: http://localhost:5273
APP_URL=http://localhost:5273

# Comma-separated list of origins allowed by CORS.
# Must match the browser Origin header exactly (including scheme and port).
# Use * only in development; production requires explicit origins.
# Default: http://localhost:5273
CORS_ORIGIN=http://localhost:5273

# ── Database ────────────────────────────────────────────────
# Postgres connection string. Neon / Supabase / RDS all work.
# Required in production. In development/test, a warning is logged if missing.
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/skillnova?sslmode=require

# ── Redis (Upstash REST) ────────────────────────────────────
# Empty values disable Redis; the cache falls back to in-memory LRU only.
# Distributed caching, rate limiting, and pub/sub will be unavailable.
# Get credentials from https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI Provider (Groq) ──────────────────────────────────────
# Get an API key at https://console.groq.com/keys
# If missing, the AI assistant endpoints return 503.
GROQ_API_KEY=
# Valid models: llama-3.1-8b-instant (fast, default), llama-3.1-70b-versatile (capable)
GROQ_MODEL=llama-3.1-8b-instant

# ── Auth Secrets ────────────────────────────────────────────
# All secrets must be set in production; the server refuses to boot without them.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# HS256 secret for signing access tokens (short-lived, 15 min default)
JWT_ACCESS_SECRET=
# HS256 secret for signing refresh tokens (long-lived, 30 days default)
JWT_REFRESH_SECRET=
# HS256 secret for short-lived helper tokens (password reset, etc.)
JWT_SECRET=
# HMAC secret for the CSRF double-submit cookie pattern
CSRF_SECRET=

# ── Service-to-service API key (signed-URL HMAC seed) ───────
# Used to generate and verify HMAC-signed file download URLs.
# If empty, signed URL generation is disabled.
API_KEY=

# ── Token TTLs (seconds) ────────────────────────────────────
# Access token lifetime in seconds. Default: 900 (15 minutes)
ACCESS_TOKEN_TTL=900
# Refresh token lifetime in seconds. Default: 2592000 (30 days)
REFRESH_TOKEN_TTL=2592000
# OTP validity window in seconds. Default: 300 (5 minutes)
OTP_TTL=300
# TOTP challenge validity window in seconds. Default: 600 (10 minutes)
TWOFA_TTL=600

# ── Rate Limiting ───────────────────────────────────────────
# Global rate-limit window in milliseconds. Default: 60000 (1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window for the global limiter. Default: 120
RATE_LIMIT_MAX=120
# Max requests per window for auth endpoints (login, OTP). Default: 10
AUTH_RATE_LIMIT_MAX=10

# ── Logging ─────────────────────────────────────────────────
# Pino log level. Valid values: trace | debug | info | warn | error | fatal
# In production, logs are JSON. In development, pretty-printed.
LOG_LEVEL=info

# ── Google OAuth (optional) ─────────────────────────────────
# Set GOOGLE_OAUTH_ENABLED=true and provide client credentials to enable
# Google OAuth sign-in. Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to true to enable the Google OAuth login flow
GOOGLE_OAUTH_ENABLED=false