# Copy to .env / server/.env and fill in your own secrets.
# This file is committed only as a template — real secrets must NEVER be committed.

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ── Database (Neon Postgres) ──────────────────────────────
DATABASE_URL=

# ── Redis (Upstash REST) ──────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI Provider (Groq) ────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# ── Auth Secrets (rotate these!) ─────────────────────────
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
JWT_SECRET=replace-me
CSRF_SECRET=replace-me

# ── API key for service-to-service calls ──────────────────
API_KEY=replace-me

# ── Token TTLs ────────────────────────────────────────────
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
OTP_TTL=10m
TWOFA_TTL=10m

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
