# ════════════════════════════════════════════════════════════
#  SkillNova — Frontend Environment (safe to commit)
#  Copy this file to .env and fill in values for your machine.
# ════════════════════════════════════════════════════════════

# Public app name shown in the UI header and browser tab.
# Default: SkillNova
VITE_APP_NAME=SkillNova

# Base URL where the frontend is served. Used for CORS redirects and OAuth callbacks.
# In development: http://localhost:5273
# In production: your public-facing domain
VITE_APP_URL=http://localhost:5273

# API base URL — the Vite dev server proxies /api requests to this origin.
# In development: http://localhost:4000/api/v1
# In production: relative path or full URL of your API server
VITE_API_URL=http://localhost:4000/api/v1

# Socket.io endpoint for real-time notifications and broadcasts.
# In development: http://localhost:4000
# In production: same origin as the API server
VITE_SOCKET_URL=http://localhost:4000

# AIAssistant backend URL — Vite proxies /api/aiassistant to this origin.
# Set to your Python AI assistant server address.
VITE_AIASSISTANT_URL=http://localhost:8000

# Backend URL used as the OAuth callback origin in development.
# Should match the API server address without trailing slash.
BACKEND_URL=http://localhost:4000

# ── AI Provider Keys (at least one required for AI features) ─
# Groq — fast inference, used by the built-in AI assistant
GROQ_API_KEY=
# Google Gemini — alternative AI provider
GEMINI_API_KEY=
# OpenAI — alternative AI provider
OPENAI_API_KEY=
# DeepSeek — alternative AI provider
DEEPSEEK_API_KEY=
# Hugging Face — required for HF inference endpoints
HUGGINGFACE_API_KEY=
HUGGINGFACE_TOKEN=
# Tavily — used for web search grounding
TAVILY_API_KEY=
