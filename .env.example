# ════════════════════════════════════════════════════════════
#  SkillNova — Frontend Environment (safe to commit)
#  Copy this file to .env and fill in values for your machine.
# ════════════════════════════════════════════════════════════

# Public app name shown in the UI
VITE_APP_NAME=SkillNova

# Where the frontend is served from (used for CORS redirects)
VITE_APP_URL=http://localhost:5273

# API base URL — the Vite dev server proxies /api to this origin
VITE_API_URL=http://localhost:4000/api/v1

# Socket.io endpoint (proxied in dev, same origin in prod)
VITE_SOCKET_URL=http://localhost:4000

# AIAssistant backend — Vite proxies /api/aiassistant to this origin
VITE_AIASSISTANT_URL=http://localhost:8000

# AIAssistant LLM provider keys (at least one required)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
HUGGINGFACE_API_KEY=
HUGGINGFACE_TOKEN=
TAVILY_API_KEY=